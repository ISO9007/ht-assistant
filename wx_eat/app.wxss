page {
  min-height: 100%;
  background: #f5fbf7;
  color: #1d2b22;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
  font-size: 34rpx;
}

view,
text,
button,
input,
picker,
textarea,
switch {
  box-sizing: border-box;
}

button {
  margin: 0;
  border: 0;
  border-radius: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 48rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.primary-button {
  min-height: 96rpx;
  padding: 28rpx 34rpx;
  background: #167a45;
  color: #ffffff;
}

.secondary-button {
  min-height: 88rpx;
  padding: 24rpx 30rpx;
  background: #e7f4eb;
  color: #135f37;
}

.danger-button {
  min-height: 88rpx;
  padding: 24rpx 30rpx;
  background: #fff0ed;
  color: #b02f20;
}

.muted {
  color: #65766b;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 54rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e7f4eb;
  color: #135f37;
  font-size: 26rpx;
  font-weight: 700;
}

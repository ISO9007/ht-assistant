.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(18, 33, 24, 0.62);
}

.modal {
  width: 100%;
  padding: 42rpx 34rpx 34rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 80rpx rgba(20, 48, 30, 0.18);
}

.alert-label {
  color: #b02f20;
  font-size: 34rpx;
  font-weight: 800;
}

.medicine-name {
  margin-top: 16rpx;
  color: #13251a;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.15;
}

.dose-box {
  margin-top: 28rpx;
  padding: 28rpx;
  border: 4rpx solid #167a45;
  border-radius: 24rpx;
  background: #f1fbf4;
}

.dose-time {
  color: #0f5f37;
  font-size: 52rpx;
  font-weight: 900;
}

.dose-index {
  margin-top: 10rpx;
  color: #41554a;
  font-size: 30rpx;
  font-weight: 700;
}

.dose-detail,
.note {
  margin-top: 22rpx;
  color: #293b30;
  font-size: 34rpx;
  line-height: 1.5;
}

.taken-button {
  width: 100%;
  min-height: 112rpx;
  margin-top: 34rpx;
  background: #167a45;
  color: #ffffff;
  font-size: 40rpx;
}

.later-button {
  width: 100%;
  min-height: 96rpx;
  margin-top: 18rpx;
  background: #eef5f0;
  color: #1f5135;
  font-size: 34rpx;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.app-title {
  color: #102016;
  font-size: 54rpx;
  font-weight: 900;
}

.date-text {
  margin-top: 8rpx;
  color: #65766b;
  font-size: 30rpx;
}

.settings-button,
.small-edit {
  flex: 0 0 auto;
  min-height: 72rpx;
  padding: 18rpx 24rpx;
  background: #e7f4eb;
  color: #135f37;
  font-size: 28rpx;
}

.next-panel,
.empty-next {
  margin-top: 30rpx;
  padding: 34rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 42rpx rgba(24, 64, 38, 0.08);
}

.next-panel-warn {
  border: 4rpx solid #c74431;
  background: #fff8f6;
}

.section-label {
  color: #167a45;
  font-size: 30rpx;
  font-weight: 900;
}

.next-name {
  margin-top: 14rpx;
  color: #17281d;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.15;
}

.next-time {
  margin-top: 16rpx;
  color: #0f5f37;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 1.1;
}

.next-dose {
  margin-top: 14rpx;
  color: #41554a;
  font-size: 30rpx;
  font-weight: 700;
}

.next-action {
  width: 100%;
  margin-top: 28rpx;
}

.action-row {
  margin-top: 24rpx;
}

.add-button {
  width: 100%;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 38rpx;
}

.section-title {
  color: #17281d;
  font-size: 42rpx;
  font-weight: 900;
}

.medicine-card,
.empty-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 36rpx rgba(24, 64, 38, 0.07);
}

.medicine-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.medicine-title {
  color: #14251a;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.18;
  word-break: break-all;
}

.medicine-sub {
  margin-top: 10rpx;
  color: #65766b;
  font-size: 30rpx;
}

.time-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.time-block {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 18rpx;
  align-items: center;
  min-height: 136rpx;
  padding: 22rpx;
  border: 3rpx solid #dbe9df;
  border-radius: 22rpx;
  background: #f9fdf9;
}

.status-due,
.status-missed {
  border-color: #c74431;
  background: #fff8f6;
}

.status-taken {
  border-color: #9dd4ae;
  background: #f0fbf3;
}

.time-label {
  color: #102016;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.1;
}

.time-index {
  margin-top: 10rpx;
  color: #65766b;
  font-size: 28rpx;
  font-weight: 700;
}

.status-pill {
  min-width: 112rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #41554a;
  background: #eef5f0;
  font-size: 26rpx;
  font-weight: 900;
}

.status-pill-due,
.status-pill-missed {
  color: #b02f20;
  background: #ffe6e0;
}

.status-pill-taken {
  color: #0f6a3d;
  background: #dff5e6;
}

.mini-taken {
  grid-column: 1 / 3;
  min-height: 82rpx;
  background: #167a45;
  color: #ffffff;
  font-size: 32rpx;
}

.empty-title {
  color: #17281d;
  font-size: 40rpx;
  font-weight: 900;
}
